# MacBook scraper .env — copy this to .env on your MacBook
# Only these two values are required. Everything else is optional.

# Your Windows machine's local IP address (e.g. 192.168.1.42)
# Find it on Windows: run `ipconfig` → look for IPv4 Address under your Wi-Fi adapter
WINDOWS_HOST=192.168.x.x

# Same password as your Windows .env POSTGRES_PASSWORD
POSTGRES_PASSWORD=your_db_password

# Optional: add these if you have API keys (same as Windows .env)
YELP_API_KEY=
FOURSQUARE_API_KEY=
